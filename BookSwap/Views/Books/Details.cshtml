@model BookSwap.Models.Book

<div class="details-container">

    <div class="details-image-section">

        <img src="@Model.ImageUrl" class="details-book-image" />

    </div>

    <div class="details-content">

        @if (Model.IsFeatured)
        {
            <span class="featured-badge">FEATURED</span>
        }

        <h1>@Model.Title</h1>

        <h3>@Model.Author</h3>

        <p class="details-genre">@Model.Genre</p>

        <p class="details-description">
            @Model.Description
        </p>

        <div class="details-status">
            Status: @Model.Status
        </div>

        <div class="mt-4">

            @if (Context.Session.GetString("IsAdmin") == "true")
            {
                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-custom">
                    Edit
                </a>
            }

            <a asp-action="Index"
               class="btn btn-custom">
                Back
            </a>

        </div>
        <div class="details-meta">

            <p><strong>Pages:</strong> @Model.Pages</p>

            <p><strong>Price:</strong> $@Model.Price</p>

            <p><strong>Language:</strong> @Model.Language</p>

            <p><strong>Published:</strong> @Model.PublishedYear</p>

            <p><strong>Rating:</strong> ⭐ @Model.Rating</p>

        </div>

    </div>

</div>