@model IEnumerable<BookSwap.Models.Book>

@{
    ViewData["Title"] = "BookSwap";
}
<section class="hero-section">

    <div class="hero-overlay"></div>

    <div class="hero-content">
        <h1>Swap Stories.<br />Discover Worlds.</h1>

        <p>
            A dark digital library where forgotten pages find new hands.
        </p>
    </div>

</section>
<form asp-action="Index"
      method="get"
      class="search-form">

    <input type="text"
           name="searchString"
           placeholder="Search books..." />

    <select name="genre">

        <option value="">All Genres</option>

        @foreach (var genre in ViewBag.Genres)
        {
            <option value="@genre">
                @genre
            </option>
        }

    </select>

    <button type="submit"
            class="btn btn-custom">
        Search
    </button>

</form>

<h1>📄 Library</h1>

@if (Context.Session.GetString("IsAdmin") == "true")
{
    <p>
        <a asp-action="Create" class="btn btn-custom">
            + Add New Book
        </a>
    </p>
}

<div class="book-grid">

    @foreach (var item in Model)
    {
        <div class="book-card @(item.IsFeatured ? "featured-card" : "")">

            <img src="@item.ImageUrl" class="book-image" />

            @if (item.IsFeatured)
            {
                <div class="featured-badge">
                    FEATURED
                </div>
            }

            <h2>@item.Title</h2>

            <p><strong>Author:</strong> @item.Author</p>

            <p><strong>Genre:</strong> @item.Genre</p>

            <p><strong>Status:</strong> @item.Status</p>

            <p>@item.Description</p>

            <div class="mt-3 d-flex gap-2 flex-wrap">
                @if (Context.Session.GetString("IsAdmin") == "true")
                {
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-custom">
                    Edit
                </a>
                }
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-custom">
                    Details
                </a>
                @if (Context.Session.GetString("IsAdmin") == "true")
                {
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-custom">
                    Delete
                </a>
                }   
            </div>

        </div>
    }

</div>