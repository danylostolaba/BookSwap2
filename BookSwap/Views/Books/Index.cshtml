@model IEnumerable<BookSwap.Models.Book>

@{
    ViewData["Title"] = "BookSwap";
}

<form asp-action="Index" method="get" class="mb-4 d-flex gap-2">
    <input type="text" name="searchString" placeholder="Search books..." />
    <input type="submit" value="Search" class="btn btn-custom" />
</form>

<h1>📚 BookSwap Library</h1>

<p>
    <a asp-action="Create" class="btn btn-custom">+ Add New Book</a>
</p>

<div class="book-grid">

    @foreach (var item in Model)
    {
        <div class="book-card @(item.IsFeatured ? "featured-card" : "")">

            <img src="@item.ImageUrl" class="book-image" />

            @if (item.IsFeatured)
            {
                <div class="featured-badge">
                    FEATURED
                </div>
            }

            <h2>@item.Title</h2>

            <p><strong>Author:</strong> @item.Author</p>

            <p><strong>Genre:</strong> @item.Genre</p>

            <p><strong>Status:</strong> @item.Status</p>

            <p>@item.Description</p>

            <div class="mt-3 d-flex gap-2 flex-wrap">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-custom">
                    Edit
                </a>

                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-custom">
                    Details
                </a>

                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-custom">
                    Delete
                </a>
            </div>

        </div>
    }

</div>