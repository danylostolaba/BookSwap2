@{
    ViewData["Title"] = "Page Not Found";
}

<div style="text-align:center; padding:120px 20px;">

    <h1 style="
        font-size:120px;
        color:#00d0ff;
        margin-bottom:0;
        text-shadow:0 0 25px rgba(0,208,255,0.35);
    ">
        404
    </h1>

    <h2 style="font-size:42px; margin-top:10px;">
        Lost Between The Pages
    </h2>

    <p style="
        color:#999;
        max-width:600px;
        margin:25px auto;
        font-size:20px;
        line-height:1.7;
    ">
        The page you are looking for does not exist
        or has vanished into the dark library.
    </p>

    <a asp-controller="Books"
       asp-action="Index"
       class="btn btn-custom"
       style="margin-top:20px;">
        Return Home
    </a>

</div>